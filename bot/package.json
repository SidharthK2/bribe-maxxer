{
  "name": "bribe-maxxer",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env --import tsx src/index.ts",
    "start:dry": "DRY_RUN=true node --env-file=.env --import tsx src/index.ts",
    "docker:build": "docker build -t bribe-maxxer .",
    "docker:run": "docker run --env-file .env -p 3000:3000 -v ./data:/app/data bribe-maxxer",
    "docker:run:dry": "docker run --env-file .env -e DRY_RUN=true -p 3000:3000 -v ./data:/app/data bribe-maxxer"
  },
  "dependencies": {
    "@flashbots/mev-share-client": "^0.7.13",
    "@hono/node-server": "^1.19.9",
    "better-sqlite3": "^12.6.2",
    "ethers": "^6.13.0",
    "hono": "^4.12.3",
    "p-limit": "^6.0.0",
    "viem": "^2.21.22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
