# ── RPC ──────────────────────────────────────────────────
API_KEY_ALCHEMY=your_alchemy_key
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${API_KEY_ALCHEMY}

# ── Deployment ───────────────────────────────────────────
PRIVATE_KEY=0x...
API_KEY_ETHERSCAN=your_etherscan_key

# ── Bot (used by bot/ off-chain monitor) ─────────────────
HTTP_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${API_KEY_ALCHEMY}
WS_RPC_URL=wss://eth-mainnet.g.alchemy.com/v2/${API_KEY_ALCHEMY}
FLASHBOTS_AUTH_KEY=0x...
FLASH_LIQUIDATOR=0x...

# ── Optional ─────────────────────────────────────────────
MIN_PROFIT_USD=5
MIN_MARKET_BORROW_USD=10000
MAX_CONCURRENT_MARKETS=20
BUNDLE_MAX_RETRIES=3
DRY_RUN=false
DISCORD_WEBHOOK_URL=
PORT=3000
